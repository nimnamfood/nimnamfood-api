<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%date{yyyy-MM-dd HH:mm:ss.SSS} [%cyan(%thread)][%highlight(%level)][%boldGreen(%logger{5})] %m%n</pattern>
        </encoder>
    </appender>

    <logger name="nimnamfood" level="DEBUG"/>
    <logger name="vtertre" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>